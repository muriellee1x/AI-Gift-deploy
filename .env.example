# ==================== Database ====================
DATABASE_URL="mysql://root:waoowaoo123@localhost:13306/aigift"

# ==================== Storage ====================
STORAGE_TYPE=minio
MINIO_ENDPOINT=http://localhost:19000
MINIO_REGION=us-east-1
MINIO_BUCKET=aigift
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_FORCE_PATH_STYLE=true

# TOS public bucket (recommended for Ark reference_video)
# STORAGE_TYPE=tos
# TOS_ENDPOINT=https://<public-web-endpoint>
# TOS_REGION=cn-beijing
# TOS_BUCKET=aigift-dev-<region-suffix>
# TOS_ACCESS_KEY=<your-access-key>
# TOS_SECRET_KEY=<your-secret-key>
# TOS_FORCE_PATH_STYLE=false

# ==================== Auth ====================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=please-change-this-to-a-random-string

# ==================== Redis ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=

# ==================== Worker ====================
QUEUE_CONCURRENCY_TEXT=10
QUEUE_CONCURRENCY_IMAGE=10
QUEUE_CONCURRENCY_VIDEO=5

# ==================== Internal ====================
API_ENCRYPTION_KEY=aigift-dev-fixed-key-2026
INTERNAL_APP_URL=http://127.0.0.1:3000
