{
  "name": "ai-gift",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "npm run storage:init && concurrently --kill-others \"npm run dev:next\" \"npm run dev:worker\"",
    "dev:next": "cross-env NODE_OPTIONS=\"--no-deprecation\" next dev --turbopack -H 0.0.0.0",
    "dev:worker": "tsx watch --env-file=.env src/lib/workers/index.ts",
    "build": "prisma generate && next build",
    "start": "npm run storage:init && concurrently --kill-others \"npm run start:next\" \"npm run start:worker\"",
    "storage:init": "tsx --env-file=.env src/lib/storage/init.ts",
    "start:next": "next start -H 0.0.0.0",
    "start:worker": "tsx --env-file=.env src/lib/workers/index.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .next"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.26",
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/s3-request-presigner": "^3.883.0",
    "@google/genai": "^1.49.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.2",
    "@tanstack/react-query": "^5.90.20",
    "ai": "^6.0.116",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.67.3",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "ioredis": "^5.9.2",
    "jsonrepair": "^3.13.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "next": "^15.5.7",
    "next-auth": "^4.24.11",
    "openai": "^6.8.1",
    "prisma": "^6.19.2",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-hot-toast": "^2.6.0",
    "sharp": "^0.34.5",
    "undici": "^7.22.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
